# xAI TTS (default for talk.sh / tts.sh)
# Copy to voice-bridge/.env, ~/.hermes/.env, or export in shell.
XAI_API_KEY=xai-your-key-here
XAI_TTS_VOICE=eve

# Optional: force local Chatterbox instead of xAI
# TTS_ENGINE=chatterbox

# Optional: disable mic after speak (read-aloud only)
# TALK_AUTO_LISTEN=0
