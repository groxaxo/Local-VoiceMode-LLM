# Local VoiceMode LLM environment reference
#
# Copy only the values you need into the shell, service manager, or launcher that
# starts your agent. The project scripts do NOT automatically load this file.
# Never commit real API credentials.

# =============================================================================
# Recommended local baseline
# =============================================================================

# Local Parakeet ONNX speech-to-text
# STT_ENGINE=local
# STT_URL=http://127.0.0.1:5093/v1/audio/transcriptions
# STT_MODEL=parakeet-tdt-0.6b-v3

# Local Supertonic 3 ONNX text-to-speech
# The managed installer runs it on :8766.
# TTS_ENGINE=supertonic
# SUPERTONIC_URL=http://127.0.0.1:8766
# SUPERTONIC_VOICE=F4                 # F1-F5 or M1-M5
# TTS_QUALITY=normal                  # normal=8 steps; high=20 steps
# SUPERTONIC_STEPS=8                  # optional explicit override, 1-20
# SUPERTONIC_SPEED=1.0
# TTS_FADE_MS=6                       # set 0 to disable WAV edge fades

# Conversation and endpointing
# TALK_AUTO_LISTEN=1
# TALK_BARGE_IN=0                     # requires echo control/headphones
# TALK_IDLE_TIMEOUT_S=300             # 0 disables the idle timeout
# TALK_STOP_PHRASES=stop talk|para de hablar
# TALK_READY_CUE=1
# TALK_BEEP=1
# TALK_BEEP_MS=150
# TALK_BEEP_FREQ=880
# VAD_THRESHOLD=0.5
# VAD_MIN_SILENCE_MS=700              # raise for longer pauses; lower for faster turns
# MIC_QUERY=Headset                   # empty/unset uses automatic selection

# =============================================================================
# Optional local TTS backends
# =============================================================================

# Supertonic 2 service (installed separately on :8880)
# Install: bash integrations/supertonic2/install.sh
# The dispatcher currently uses the normal `supertonic` engine with the alternate URL.
# TTS_ENGINE=supertonic
# SUPERTONIC_URL=http://127.0.0.1:8880

# NeuTTS GGUF service
# TTS_ENGINE=neutts
# NEUTTS_URL=http://127.0.0.1:8020
# NEUTTS_MODEL=neuphonic/neutts-nano-q8-gguf
# NEUTTS_MODEL_ES=neuphonic/neutts-nano-spanish-q8-gguf
# NEUTTS_MODEL_DE=neuphonic/neutts-nano-german-q8-gguf
# NEUTTS_MODEL_FR=neuphonic/neutts-nano-french-q8-gguf

# Inflect Nano (experimental, English only)
# TTS_ENGINE=inflect
# INFLECT_URL=http://127.0.0.1:8030

# Qwen3-TTS MLX service (separate installation, primarily Apple Silicon)
# TTS_ENGINE=qwen
# QWEN_TTS_QUALITY=hq                # fast | hq | lazy
# QWEN_TTS_URL_FAST=http://127.0.0.1:18881
# QWEN_TTS_URL_HQ=http://127.0.0.1:18882
# QWEN_TTS_URL_LAZY=http://127.0.0.1:18883
# QWEN_TTS_VOICE=vivian

# =============================================================================
# Optional remote OpenAI-compatible speech
# =============================================================================

# Remote TTS. OPENAI_TTS_URL is a base URL; /audio/speech is appended.
# TTS_ENGINE=openai
# OPENAI_TTS_URL=https://api.openai.com/v1
# OPENAI_TTS_KEY=replace-me            # OPENAI_API_KEY is used when unset
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=alloy
# OPENAI_TTS_FORMAT=wav

# Remote STT on Unix talk.sh
# STT_ENGINE=remote
# STT_REMOTE_URL=https://api.openai.com/v1/audio/transcriptions
# STT_REMOTE_MODEL=whisper-1
# STT_API_KEY=replace-me               # or STT_REMOTE_KEY / OPENAI_API_KEY

# Example LAN server without public cloud credentials
# TTS_ENGINE=openai
# OPENAI_TTS_URL=http://192.168.1.50:8000/v1
# OPENAI_TTS_KEY=local-token

# =============================================================================
# Optional hosted providers
# =============================================================================

# Inworld expressive TTS
# TTS_ENGINE=inworld
# INWORLD_API_KEY=replace-with-basic-base64-key
# INWORLD_TTS_VOICE=Ashley
# INWORLD_TTS_MODEL=inworld-tts-2
# INWORLD_STEER=auto                   # auto | 1 | 0
# INWORLD_STEER_PERSONA=
# INWORLD_TTS_ENCODING=LINEAR16
# INWORLD_TTS_SAMPLE_RATE=48000

# xAI TTS
# TTS_ENGINE=xai
# XAI_API_KEY=replace-me
# XAI_TTS_VOICE=eve
# XAI_TTS_MODEL=grok-2-audio

# =============================================================================
# Optional Ollama voice integration
# =============================================================================

# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_VOICE_MODEL=llama3.2
# OLLAMA_VOICE_STREAM_TTS=1
# OLLAMA_VOICE_THINK=false
# OLLAMA_VOICE_NUM_PREDICT=400
# OLLAMA_VOICE_HISTORY=20
